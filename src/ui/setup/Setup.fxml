<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Slider?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.setup.SetupController"
      alignment="CENTER"
      spacing="20">

    <Label text="Game Setup" />

    <fx:include fx:id="mapSetup" source="MapSetup.fxml" VBox.vgrow="ALWAYS"/>
    <fx:include fx:id="gameSetup" source="GameSetup.fxml" VBox.vgrow="ALWAYS"/>

    <Button fx:id="startGameButton" text="Start Game" onAction="#handleStartGame"/>
    <Button fx:id="backToMenuButton" text="Back" onAction="#handleBackToMenu"/>

</VBox>