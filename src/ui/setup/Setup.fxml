<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<VBox alignment="TOP_CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.setup.SetupController" fx:id="root">

    <!--title padding-->
    <padding>
        <Insets top="20"/>
    </padding>
    <!--title-->
    <Label text="Game Setup" fx:id="titleLabel"/>

    <!--setup pannels-->
    <HBox VBox.vgrow="ALWAYS">

        <!--map pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert map stats"></Label>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Height"/>
                <Spinner fx:id="mapHeightSpinner"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Width"/>
                <Spinner fx:id="mapWidthSpinner"/>
            </HBox>

        </VBox>

        <!--player pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert player stats"></Label>

            <GridPane fx:id="playerGrid" alignment="CENTER"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

        </VBox>

        <!--object pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert object stats"></Label>

            <GridPane fx:id="objectGrid">

            </GridPane>

            <Button fx:id="addObjectButton" text="+" onAction="#handleAddObject"/>

        </VBox>

        <!--monster pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert monster coordinates"></Label>

        </VBox>

    </HBox>

</VBox>