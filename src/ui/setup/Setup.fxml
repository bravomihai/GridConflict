<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TextField?>
<VBox alignment="TOP_CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.setup.SetupController" fx:id="root">

    <!--title padding-->
    <padding>
        <Insets top="20"/>
    </padding>
    <!--title-->
    <Label text="Game Setup" fx:id="titleLabel"/>

    <!--setup pannels-->
    <HBox VBox.vgrow="ALWAYS">

        <!--map pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert map stats"></Label>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Height"/>
                <TextField fx:id="mapHeightField"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Width"/>
                <TextField fx:id="mapWidthField"/>
            </HBox>

        </VBox>

        <!--player pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert player stats"></Label>

            <GridPane fx:id="playerGrid" alignment="CENTER"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

        </VBox>

        <!--item pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert item stats"></Label>

            <GridPane fx:id="itemGrid" alignment="CENTER"/>

            <Button fx:id="addItemButton" text="+" onAction="#handleAddItem"/>

        </VBox>

        <!--monster pannel-->
        <VBox alignment="CENTER" spacing="20"
              HBox.hgrow="ALWAYS" maxWidth="Infinity">

            <Label text="insert monster coordinates"></Label>

            <GridPane fx:id="monsterGrid" alignment="CENTER"/>

            <Button fx:id="addMonsterButton" text="+" onAction="#handleAddMonster"/>

        </VBox>

    </HBox>

    <Button fx:id="startGameButton" text="Start Game" onAction="#handleStartGame"/>

    <padding>
        <Insets top="20"/>
    </padding>

    <Button fx:id="backToMenuButton" text="Back" onAction="#handleBackToMenu"/>

    <padding>
        <Insets top="20"/>
    </padding>

</VBox>